APP_NAME=AllLeads
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=bg_BG

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -------------------------------------------------------------------
# Database — MySQL 8 (matches Docker Compose and DigitalOcean Managed MySQL)
# -------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=mysql        # use 127.0.0.1 outside Docker
DB_PORT=3306
DB_DATABASE=allleads
DB_USERNAME=allleads
DB_PASSWORD=secret   # REQUIRED — change in production

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database   # no Redis needed

CACHE_STORE=database        # no Redis needed

# -------------------------------------------------------------------
# Mail — log driver for local dev (emails written to storage/logs/laravel.log)
# In production use Brevo SMTP or switch MAIL_MAILER=brevo
# -------------------------------------------------------------------
MAIL_MAILER=log
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=                # your Brevo login email
MAIL_PASSWORD=                # your Brevo SMTP key (NOT account password)
MAIL_FROM_ADDRESS="noreply@alll.nsh.one"
MAIL_FROM_NAME="${APP_NAME}"

# -------------------------------------------------------------------
# Brevo — transactional API + inbound webhook
# Get API key from: Brevo → Settings → API Keys
# -------------------------------------------------------------------
BREVO_API_KEY=              # REQUIRED for email sending
BREVO_WEBHOOK_SECRET=       # REQUIRED — used to verify inbound webhook HMAC signatures

# -------------------------------------------------------------------
# AI Providers — free tiers available on all three
# -------------------------------------------------------------------
AI_PROVIDER=openrouter      # default provider: openrouter | groq | gemini

OPENROUTER_API_KEY=         # https://openrouter.ai/keys
GROQ_API_KEY=               # https://console.groq.com/keys
GEMINI_API_KEY=             # https://aistudio.google.com/app/apikey

# -------------------------------------------------------------------
# Admin / Seeder credentials
# -------------------------------------------------------------------
ADMIN_EMAIL=admin@allleads.local    # REQUIRED — used by AdminSeeder
ADMIN_PASSWORD=password             # REQUIRED — change before first deploy

VITE_APP_NAME="${APP_NAME}"

